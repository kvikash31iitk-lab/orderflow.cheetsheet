# ============================================================================
# Vikings Order Flow Terminal — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# --- TrueData (Market Data WebSocket) ---------------------------------------
# Provide your real TrueData credentials in `.env` (never commit them).
TRUEDATA_USERNAME=your_truedata_username
TRUEDATA_PASSWORD=your_truedata_password
TRUEDATA_LIVE_PORT=8086
TRUEDATA_URL=push.truedata.in
# Comma-separated. Trial allows up to 50 symbols. "-I" = continuous front-month future.
TRUEDATA_SYMBOLS=NIFTY-I,BANKNIFTY-I,FINNIFTY-I,MIDCPNIFTY-I

# If TrueData is unreachable / market closed, run a synthetic feed so the UI works.
# Set to "false" to force a real connection only.
USE_SIMULATOR_FALLBACK=true
# Set to "true" to ALWAYS use the simulator and never touch TrueData (offline dev).
FORCE_SIMULATOR=false

# --- Databento (CME/COMEX futures market data) ------------------------------
# Provide your real Databento API key in `.env` (never commit it).
DATABENTO_API_KEY=your_databento_api_key
# Comma-separated continuous futures symbols (e.g. Euro FX, Gold).
DATABENTO_SYMBOLS=6E.v.0,GC.v.0

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=orderflow
POSTGRES_USER=orderflow
POSTGRES_PASSWORD=orderflow_pw

# --- Redis ------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Order flow engine tuning ----------------------------------------------
# Default timeframe candles are aggregated into (see app/config.py for the list).
DEFAULT_TIMEFRAME=2m
# Exchange timezone offset (minutes east of UTC) anchoring the daily VWAP reset to
# the exchange calendar day. 330=IST (NSE/MCX), -300=US Eastern (EST), 0=UTC.
EXCHANGE_TIMEZONE_OFFSET_MINUTES=330
# Exchange session open ("HH:MM", exchange-local). Daily VWAP resets here, not at
# calendar midnight. "09:15" for NSE equity/F&O, "00:00" to reset at midnight.
EXCHANGE_SESSION_START=09:15
# Imbalance ratio threshold (ask/bid or bid/ask) to flag a footprint cell.
IMBALANCE_RATIO=3.0
# Minimum cell volume before an imbalance is considered (filters noise).
IMBALANCE_MIN_VOLUME=50
# Consecutive same-direction imbalances to mark a stacked-imbalance zone.
STACKED_IMBALANCE_COUNT=3
# Absorption: volume >= mean+Nσ while price range <= this many ticks.
ABSORPTION_VOLUME_STD=2.0
ABSORPTION_MAX_RANGE_TICKS=2
# Exhaustion: new extreme while extreme-side volume drops below this fraction
# of the candle's average level volume.
EXHAUSTION_VOLUME_FRACTION=0.35
# AD (Aggressive Delta): |delta| percentile threshold over rolling window.
AD_DELTA_PERCENTILE=90
AD_ROLLING_WINDOW=50
# LP (Liquidity Provider): huge volume + small body + strong opposite defense.
LP_VOLUME_STD=2.0
LP_MAX_BODY_FRACTION=0.30
# Volume cluster / node detection.
VOLUME_CLUSTER_PERCENTILE=95

# --- Alerts -----------------------------------------------------------------
ALERTS_ENABLED=true
ALERT_SOUND_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=

# --- App --------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
# Where raw tick recordings (parquet) are written.
TICK_RECORDING_DIR=/data/ticks
# Frontend origin allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
